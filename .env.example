# ==============================================
# Checkmate Backend - 환경변수 템플릿
# ==============================================
# 이 파일은 git에 포함됩니다. 값은 절대 입력하지 마세요.
# 실제 값은 .env 파일에 입력하세요.
# 새로운 환경변수가 추가되면 이 파일에도 키를 추가해주세요.
# ==============================================

# ----------------------------------------------
# App
# ----------------------------------------------
NODE_ENV=development          # development | staging | production
PORT=8080
API_PREFIX=api
CORS_ORIGIN=http://localhost:5173

# ----------------------------------------------
# Database (PostgreSQL / Supabase)
# ----------------------------------------------
# 예시(로컬 Postgres): postgresql://postgres:postgres@localhost:5432/checkmate?schema=public
# 예시(Supabase Pooler): postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=
# 마이그레이션/스튜디오 전용(Direct connection, Supabase 사용 시 필수)
DIRECT_URL=

# ----------------------------------------------
# Supabase (Auth JWT 검증)
# ----------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------
# Social Login (소셜 로그인 중개)
# ----------------------------------------------
# Google/Kakao 는 Supabase Auth 가 직접 처리. Naver 는 백엔드에서 중개한다.
# 로그인 성공 후 프론트로 리다이렉트할 URL (access_token 을 query/fragment 로 전달)
FRONTEND_AUTH_CALLBACK_URL=http://localhost:5173/auth/callback
# Dev 환경에서 SUPABASE_JWT_SECRET 미설정 시 인증 바이패스(=dev-anon) 허용 여부
AUTH_DEV_BYPASS=true
# 네이버 개발자 콘솔 > 애플리케이션 등록 > Client ID / Secret
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
# 네이버 콘솔 Callback URL (백엔드). 운영에서는 https 도메인으로 교체.
NAVER_REDIRECT_URI=http://localhost:8080/api/auth/naver/callback

# ----------------------------------------------
# Redis (BullMQ - LLM 비동기 처리, 이벤트 수집)
# ----------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----------------------------------------------
# LLM Provider
# ----------------------------------------------
LLM_PROVIDER=openai           # openai | anthropic | gemini
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
